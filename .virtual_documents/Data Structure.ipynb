# enumerate
'''
Enumerate function used to print both index and value of a list.
It returns two values index and value of a list.
'''


names = ['Bob', 'Charles', 'Edward', 'Bayek']
for idx, val in enumerate(names):
    print(f'{idx}: {val}')


# 1 row and multiple columns
