# Multi D List
# --------------
# Multiple Row and Multiple columns

multi_a = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
]
multi_a


'''
Nested For
---------------
Outer For loop -> Loop row
Inner For loop -> Loop column
'''


for row in multi_a: # loop row
    for column in row: # loop column
        print(column)
    else:
        print('Inner Loop')
else:
    print('Outer Loop')





